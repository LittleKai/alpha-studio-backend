{
  "id": "mod-decor-fairy-lights",
  "version": 1,
  "name": {
    "vi": "Dây đèn đom đóm LED (Module)",
    "en": "LED Fairy Lights String (Module)"
  },
  "description": {
    "vi": "Sợi dây căng đính hàng loạt bóng LED siêu nhỏ vàng rực để bao quanh khung giường hoặc cửa sổ.",
    "en": "Tension wire dotted with tiny bright yellow LEDs glowing softly across frames."
  },
  "category": "other",
  "tags": [
    "accessory",
    "fairy",
    "lights",
    "led",
    "string",
    "decor",
    "module"
  ],
  "params": {
    "length": {
      "type": "number",
      "min": 100,
      "max": 500,
      "default": 300
    }
  },
