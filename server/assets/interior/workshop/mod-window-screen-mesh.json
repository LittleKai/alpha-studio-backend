{
  "id": "mod-window-screen-mesh",
  "version": 1,
  "name": {
    "vi": "Lưới chống muỗi cửa sổ (Module)",
    "en": "Window Anti-mosquito Mesh (Module)"
  },
  "description": {
    "vi": "Phiến lưới mật độ cao cản côn trùng lọt vào phòng ngủ qua cửa sổ.",
    "en": "High density grey mesh pane blocking insects flowing through the windows."
  },
  "category": "other",
  "tags": [
    "accessory",
    "window",
    "screen",
    "mesh",
    "module",
    "bedroom"
  ],
  "params": {
    "width": {
      "type": "number",
