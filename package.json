{
  "name": "alpha-studio-backend",
  "version": "1.0.0",
  "description": "Backend API for Alpha Studio - AI Academy Platform",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "server": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "node --test \"test/*.test.js\" \"server/**/*.test.js\" \"server/**/*.test.mjs\"",
    "test:mongodb-m0": "node --test test/*mongodb-m0*.test.js test/storage-adapters.test.js test/inline-media.test.js test/retention.test.js",
    "check": "node --check server/index.js",
    "db:test": "node server/db/test-connection.js",
    "db:init": "node server/db/init-collections.js",
    "db:migrate-passwords": "node server/db/migrate-passwords.js",
    "db:m0:migrate": "node scripts/migrate-mongodb-m0.mjs",
    "db:m0:rollback": "node scripts/rollback-mongodb-m0.mjs",
    "db:m0:audit": "node scripts/audit-mongodb-m0.mjs",
    "seed:interior-templates": "node scripts/seed-interior-templates.mjs",
    "sync:interior-assets": "node scripts/sync-interior-assets.mjs",
    "import:skills": "node scripts/import-skills.js"
  },
  "keywords": [
    "express",
    "mongodb",
    "jwt",
    "auth",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@google/genai": "^1.51.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.4",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
