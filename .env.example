MONGODB_URI=mongodb+srv://user:password@example.mongodb.net/alpha-studio
MONGODB_MAX_POOL_SIZE=5
MONGODB_MIN_POOL_SIZE=0
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_MAX_IDLE_TIME_MS=60000
JWT_SECRET=replace_with_a_long_random_secret
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Optional comma/space separated extra browser origins for CORS.
# Production defaults already include https://giaiphapsangtao.com and
# https://www.giaiphapsangtao.com.
FRONTEND_URLS=
CORS_ORIGINS=

# File/media persistence. Production should use B2.
STORAGE_PROVIDER=b2
B2_ENDPOINT=
B2_REGION=us-west-004
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_BUCKET_NAME=
CDN_BASE_URL=

# Development/test alternative only.
LOCAL_STORAGE_ROOT=./.data/storage
LOCAL_STORAGE_PUBLIC_URL=http://localhost:3001/storage

# AI chat routing
# OpenClaw gateway (có session memory) — chỉ dùng khi admin bật useOpenClawForChat=true
OPENCLAW_URL=http://localhost:18791/api/chat
# Token gửi kèm header x-api-token tới OpenClaw api-server (khớp API_TOKEN phía server)
OPENCLAW_API_TOKEN=

# gcli direct — gọi thẳng upstream https://gcli.ggchan.dev (không qua local proxy)
# Dùng cho: interior tool (luôn) + AI bot khi admin tắt OpenClaw
#
# Single key (legacy, weight = 1):
#   GCLI_API_KEY=gg-gcli-xxxxx
#
# Multiple keys với weighted random pool (định dạng `key:weight,key:weight`):
#   - Mỗi key có thể kèm `:weight` (số > 0). Bỏ qua weight → mặc định 1.
#   - Mỗi request backend chọn 1 key theo xác suất tỉ lệ với weight.
#   - Dùng để chia tải / dùng đồng thời nhiều account gcli.
# Ví dụ:
#   GCLI_API_KEY=gg-gcli-aaaa:3,gg-gcli-bbbb:1,gg-gcli-cccc:2
#   → aaaa: 3/6, bbbb: 1/6, cccc: 2/6.
GCLI_API_KEY=gg-gcli-xxxxx
GCLI_DIRECT_URL=https://gcli.ggchan.dev/v1/chat/completions
GCLI_DIRECT_MODEL=gemini-2.5-flash

# Local First Live Chat mode flag
LOCAL_FIRST_LIVE_CHAT=true
